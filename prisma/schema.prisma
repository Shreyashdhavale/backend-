generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Registration {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  teamName           String
  teamSize           Int
  pptLink            String
  videoLink          String
  paymentScreenshot  String
  registrationStatus String   @default("pending")
  createdAt          DateTime @default(now())

  // 1-1 Leader
  leaderId String      @unique @db.ObjectId
  leader   Participant @relation("LeaderRelation", fields: [leaderId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // 1-many Members — Registration stores the array of IDs
  memberIds String[]      @db.ObjectId
  members   Participant[] @relation("MemberRelation", fields: [memberIds], references: [id])
}

model Participant {
  id                   String  @id @default(auto()) @map("_id") @db.ObjectId
  firstName            String
  lastName             String
  email                String
  mobile               String
  gender               String
  instituteName        String
  type                 String
  course               String
  courseSpecialization String
  graduationYear       String
  receipt              String?

  // back-relations only — no fields/references needed on this side
  registrationLeader Registration? @relation("LeaderRelation")

  // For MemberRelation, Participant side holds the back-reference IDs
  registrationMemberIds String[]      @db.ObjectId
  registrationMember    Registration[] @relation("MemberRelation", fields: [registrationMemberIds], references: [id])
}